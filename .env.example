# ── Soro.hu Backend – Környezeti változók ───────────────────────────────────
# Másold át .env-nek és töltsd ki az értékeket

# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=cseréld-le-egy-erős-véletlen-stringre

# Adatbázis
# Fejlesztéshez SQLite, production-ban PostgreSQL ajánlott:
DATABASE_URL=sqlite+aiosqlite:///./soro.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/soro_db

# JWT
JWT_SECRET=cseréld-le-egy-erős-véletlen-stringre

# Anthropic API – https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# CORS – vesszővel elválasztott originok
ALLOWED_ORIGINS=["https://soro.hu","http://localhost:3000"]

# Railway / Render: PORT automatikusan be van állítva
# PORT=8000
